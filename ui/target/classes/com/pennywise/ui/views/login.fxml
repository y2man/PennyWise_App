<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import org.kordamp.ikonli.javafx.*?>
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pennywise.ui.controller.LoginController"
      styleClass="auth-root" prefWidth="920" prefHeight="620">
  <VBox styleClass="auth-left" prefWidth="400" minWidth="360">
    <padding><Insets top="48" right="40" bottom="40" left="48"/></padding>
    <HBox alignment="CENTER_LEFT" spacing="10">
      <FontIcon iconLiteral="fas-coins" iconSize="26" styleClass="logo-icon-fa"/>
      <Label text="PennyWise" styleClass="auth-logo-text"/>
    </HBox>
    <Region VBox.vgrow="ALWAYS"/>
    <Label text="Track every penny," styleClass="auth-hero-1"/>
    <Label text="own your future." styleClass="auth-hero-2"/>
    <Region prefHeight="14"/>
    <Label text="Your personal finance companion — beautiful, smart, always at your fingertips." styleClass="auth-hero-sub" wrapText="true"/>
    <Region VBox.vgrow="ALWAYS"/>
    <VBox spacing="10">
      <HBox styleClass="deco-card" spacing="12" alignment="CENTER_LEFT"><padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
        <FontIcon iconLiteral="fas-chart-line" iconSize="13" styleClass="deco-icon-green"/>
        <VBox><Label text="Monthly Income" styleClass="deco-label"/><Label text="+4,250.00" styleClass="deco-val-green"/></VBox>
      </HBox>
      <HBox styleClass="deco-card" spacing="12" alignment="CENTER_LEFT"><padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
        <FontIcon iconLiteral="fas-chart-bar" iconSize="13" styleClass="deco-icon-red"/>
        <VBox><Label text="Expenses" styleClass="deco-label"/><Label text="-1,830.50" styleClass="deco-val-red"/></VBox>
      </HBox>
      <HBox styleClass="deco-card" spacing="12" alignment="CENTER_LEFT"><padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
        <FontIcon iconLiteral="fas-wallet" iconSize="13" styleClass="deco-icon-gold"/>
        <VBox><Label text="Net Balance" styleClass="deco-label"/><Label text="2,419.50" styleClass="deco-val-gold"/></VBox>
      </HBox>
    </VBox>
  </VBox>
  <StackPane styleClass="auth-right" HBox.hgrow="ALWAYS">
    <!-- LOGIN -->
    <VBox fx:id="loginPane" styleClass="auth-form-box" spacing="0" alignment="TOP_CENTER">
      <padding><Insets top="52" right="52" bottom="40" left="52"/></padding>
      <Label text="Welcome back" styleClass="auth-title"/>
      <Label text="Sign in to continue to your dashboard" styleClass="auth-subtitle"/>
      <Region prefHeight="28"/>
      <Label text="Email address" styleClass="field-label"/>
      <Region prefHeight="6"/>
      <TextField fx:id="loginEmail" styleClass="pw-field" promptText="you@example.com"/>
      <Region prefHeight="16"/>
      <Label text="Password" styleClass="field-label"/>
      <Region prefHeight="6"/>
      <PasswordField fx:id="loginPassword" styleClass="pw-field" promptText="••••••••"/>
      <Region prefHeight="8"/>
      <HBox alignment="CENTER_RIGHT">
        <Button text="Forgot password?" styleClass="link-btn" onAction="#goToForgot"/>
      </HBox>
      <Region prefHeight="6"/>
      <Label fx:id="loginError" styleClass="error-label" text="" wrapText="true"/>
      <Region prefHeight="14"/>
      <Button text="Sign In" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleLogin"/>
      <Region prefHeight="20"/>
      <HBox alignment="CENTER" spacing="5">
        <Label text="Don't have an account?" styleClass="color-muted"/>
        <Button text="Create one" styleClass="link-btn" onAction="#goToSignup"/>
      </HBox>
    </VBox>
    <!-- FORGOT -->
    <VBox fx:id="forgotPane" styleClass="auth-form-box" spacing="0" alignment="TOP_CENTER" visible="false" managed="false">
      <padding><Insets top="40" right="52" bottom="40" left="52"/></padding>
      <Button text="← Back to login" styleClass="back-btn" onAction="#goToLogin"/>
      <Region prefHeight="20"/>
      <FontIcon iconLiteral="fas-key" iconSize="34" styleClass="step-icon"/>
      <Region prefHeight="12"/>
      <Label text="Forgot password?" styleClass="auth-title"/>
      <Label text="Enter your email and we will send a 6-digit reset code." styleClass="auth-subtitle" wrapText="true"/>
      <Region prefHeight="24"/>
      <Label text="Email address" styleClass="field-label"/>
      <Region prefHeight="6"/>
      <TextField fx:id="forgotEmail" styleClass="pw-field" promptText="you@example.com"/>
      <Region prefHeight="8"/>
      <Label fx:id="forgotError" styleClass="error-label" text="" wrapText="true"/>
      <Label fx:id="forgotSuccess" styleClass="success-label" text="" wrapText="true"/>
      <Region prefHeight="16"/>
      <Button text="Send reset code" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleForgot"/>
    </VBox>
    <!-- VERIFY OTP -->
    <VBox fx:id="verifyPane" styleClass="auth-form-box" spacing="0" alignment="TOP_CENTER" visible="false" managed="false">
      <padding><Insets top="40" right="52" bottom="40" left="52"/></padding>
      <Button text="← Change email" styleClass="back-btn" onAction="#goToForgot"/>
      <Region prefHeight="20"/>
      <FontIcon iconLiteral="fas-envelope" iconSize="34" styleClass="step-icon"/>
      <Region prefHeight="12"/>
      <Label text="Check your email" styleClass="auth-title"/>
      <Label fx:id="sentToLabel" text="Code sent to your email" styleClass="auth-subtitle" wrapText="true"/>
      <Region prefHeight="24"/>
      <HBox spacing="8" alignment="CENTER">
        <TextField fx:id="otp0" styleClass="otp-box" prefWidth="46" prefHeight="54" maxWidth="46"/>
        <TextField fx:id="otp1" styleClass="otp-box" prefWidth="46" prefHeight="54" maxWidth="46"/>
        <TextField fx:id="otp2" styleClass="otp-box" prefWidth="46" prefHeight="54" maxWidth="46"/>
        <Label text="—" styleClass="otp-dash"/>
        <TextField fx:id="otp3" styleClass="otp-box" prefWidth="46" prefHeight="54" maxWidth="46"/>
        <TextField fx:id="otp4" styleClass="otp-box" prefWidth="46" prefHeight="54" maxWidth="46"/>
        <TextField fx:id="otp5" styleClass="otp-box" prefWidth="46" prefHeight="54" maxWidth="46"/>
      </HBox>
      <Region prefHeight="10"/>
      <Label fx:id="otpError" styleClass="error-label" text="" alignment="CENTER" maxWidth="Infinity"/>
      <Region prefHeight="16"/>
      <Button text="Verify code" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleVerify"/>
      <Region prefHeight="14"/>
      <HBox alignment="CENTER" spacing="6">
        <Label text="Code not arrived?" styleClass="color-muted"/>
        <Button text="Resend" styleClass="link-btn" onAction="#handleResend"/>
      </HBox>
    </VBox>
    <!-- RESET -->
    <VBox fx:id="resetPane" styleClass="auth-form-box" spacing="0" alignment="TOP_CENTER" visible="false" managed="false">
      <padding><Insets top="40" right="52" bottom="40" left="52"/></padding>
      <FontIcon iconLiteral="fas-lock" iconSize="34" styleClass="step-icon"/>
      <Region prefHeight="12"/>
      <Label text="Set new password" styleClass="auth-title"/>
      <Label text="Choose a strong new password." styleClass="auth-subtitle"/>
      <Region prefHeight="24"/>
      <Label text="New password" styleClass="field-label"/>
      <Region prefHeight="6"/>
      <PasswordField fx:id="newPassword" styleClass="pw-field" promptText="Min. 6 characters"/>
      <Region prefHeight="8"/>
      <ProgressBar fx:id="strengthBar" progress="0" maxWidth="Infinity" styleClass="strength-bar"/>
      <Label fx:id="strengthLabel" text="" styleClass="strength-label"/>
      <Region prefHeight="14"/>
      <Label text="Confirm new password" styleClass="field-label"/>
      <Region prefHeight="6"/>
      <PasswordField fx:id="confirmPassword" styleClass="pw-field" promptText="Repeat password"/>
      <Region prefHeight="8"/>
      <Label fx:id="resetError" styleClass="error-label" text="" wrapText="true"/>
      <Region prefHeight="16"/>
      <Button text="Set new password" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleReset"/>
    </VBox>
  </StackPane>
</HBox>
