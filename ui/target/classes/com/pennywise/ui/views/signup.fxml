<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import org.kordamp.ikonli.javafx.*?>
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pennywise.ui.controller.SignupController"
      styleClass="auth-root" prefWidth="920" prefHeight="620">
  <VBox styleClass="auth-left" prefWidth="400" minWidth="360">
    <padding><Insets top="48" right="40" bottom="40" left="48"/></padding>
    <HBox alignment="CENTER_LEFT" spacing="10">
      <FontIcon iconLiteral="fas-coins" iconSize="26" styleClass="logo-icon-fa"/>
      <Label text="PennyWise" styleClass="auth-logo-text"/>
    </HBox>
    <Region VBox.vgrow="ALWAYS"/>
    <Label text="Start tracking" styleClass="auth-hero-1"/>
    <Label text="your money today." styleClass="auth-hero-2"/>
    <Region prefHeight="14"/>
    <Label text="Create a free account and take control of your finances in minutes." styleClass="auth-hero-sub" wrapText="true"/>
    <Region VBox.vgrow="ALWAYS"/>
    <VBox spacing="12">
      <HBox spacing="10" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-check-circle" iconSize="13" styleClass="deco-icon-green"/><Label text="3 accounts: Card, Cash, Savings" styleClass="deco-label"/></HBox>
      <HBox spacing="10" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-check-circle" iconSize="13" styleClass="deco-icon-green"/><Label text="Budget limits and savings goals" styleClass="deco-label"/></HBox>
      <HBox spacing="10" alignment="CENTER_LEFT"><FontIcon iconLiteral="fas-check-circle" iconSize="13" styleClass="deco-icon-green"/><Label text="Smart balance guard — no negatives" styleClass="deco-label"/></HBox>
    </VBox>
  </VBox>
  <VBox styleClass="auth-right auth-form-box" HBox.hgrow="ALWAYS" alignment="TOP_CENTER">
    <padding><Insets top="48" right="52" bottom="40" left="52"/></padding>
    <Label text="Create account" styleClass="auth-title"/>
    <Label text="Free forever. No credit card needed." styleClass="auth-subtitle"/>
    <Region prefHeight="28"/>
    <Label text="Full name" styleClass="field-label"/>
    <Region prefHeight="6"/>
    <TextField fx:id="nameField" styleClass="pw-field" promptText="Your name"/>
    <Region prefHeight="16"/>
    <Label text="Email address" styleClass="field-label"/>
    <Region prefHeight="6"/>
    <TextField fx:id="emailField" styleClass="pw-field" promptText="you@example.com"/>
    <Region prefHeight="16"/>
    <Label text="Password" styleClass="field-label"/>
    <Region prefHeight="6"/>
    <PasswordField fx:id="passwordField" styleClass="pw-field" promptText="Min. 6 characters"/>
    <Region prefHeight="8"/>
    <ProgressBar fx:id="strengthBar" progress="0" maxWidth="Infinity" styleClass="strength-bar"/>
    <Label fx:id="strengthLabel" text="" styleClass="strength-label"/>
    <Region prefHeight="14"/>
    <Label text="Confirm password" styleClass="field-label"/>
    <Region prefHeight="6"/>
    <PasswordField fx:id="confirmField" styleClass="pw-field" promptText="Repeat password"/>
    <Region prefHeight="8"/>
    <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
    <Region prefHeight="16"/>
    <Button text="Create account" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleSignup"/>
    <Region prefHeight="20"/>
    <HBox alignment="CENTER" spacing="5">
      <Label text="Already have an account?" styleClass="color-muted"/>
      <Button text="Sign in" styleClass="link-btn" onAction="#goToLogin"/>
    </HBox>
  </VBox>
</HBox>
